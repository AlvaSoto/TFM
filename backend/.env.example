# ============================================================
# Smart Water Monitor — configuración del kit de piloto
# Copia este fichero a .env y rellena lo que apliques.
# ============================================================

# --- Ingesta de lecturas reales (OBLIGATORIO para el piloto) ---
# Clave que debe enviar el dispositivo/pasarela en la cabecera X-API-Key.
# Genera una: python -c "import secrets; print(secrets.token_urlsafe(32))"
INGEST_API_KEY=

# --- Asistente IA del dashboard ciudadano (opcional) ---
OPENAI_API_KEY=

# --- Alertas por email al confirmarse una fuga (opcional) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_FROM=alertas@tudominio.com
ALERT_EMAIL_TO=mantenimiento@cliente.com

# --- Alertas por webhook: Slack/Teams/n8n/Zapier (opcional) ---
ALERT_WEBHOOK_URL=
